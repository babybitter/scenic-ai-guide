APP_NAME=Lingshan AI Guide
NODE_ENV=development
HOST=127.0.0.1
PORT=5178
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
JWT_SECRET=replace-with-a-long-random-secret
DATA_DIR=./data
UPLOAD_DIR=./data/uploads
# SQLite database file. Leave unset to let the server use ./data/scenic.sqlite.
# Test/eval scripts ignore this and run against an in-memory database.
SQLITE_PATH=./data/scenic.sqlite
# Default iFlytek interactive-avatar id / voice seeded into the digital-human config.
DEFAULT_AVATAR_ID=cnrmkf0e2000000006
DEFAULT_AVATAR_VCN=x6_jingqudaolannvsheng_mini
# Optional explicit path to the official behaviour analytics Excel.
BEHAVIOR_XLSX=../docs/scenic-materials/景点景区旅游数据行为分析数据.xlsx
DEMO_MODE=true
# LLM provider: "mock" (offline, no key needed) or "openai" (any OpenAI /chat/completions compatible endpoint)
# For a real cloud model set LLM_PROVIDER=openai and fill the values below.
#   DeepSeek:      LLM_BASE_URL=https://api.deepseek.com/v1        LLM_MODEL=deepseek-chat
#   Qwen/DashScope LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1  LLM_MODEL=qwen-plus
#   Moonshot:      LLM_BASE_URL=https://api.moonshot.cn/v1         LLM_MODEL=moonshot-v1-8k
#   OpenAI:        LLM_BASE_URL=https://api.openai.com/v1          LLM_MODEL=gpt-4o-mini
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_MS=20000
LLM_MAX_RETRIES=2
LLM_TEMPERATURE=0.4
ASR_PROVIDER=mock
ASR_API_KEY=
TTS_PROVIDER=mock
TTS_API_KEY=
XFYUN_APP_ID=
XFYUN_API_KEY=
XFYUN_API_SECRET=
XFYUN_TTS_VOICE=x4_xiaoyan

# API key checklist for final competition deployment:
# 1. LLM_API_KEY: required only when LLM_PROVIDER=openai.
# 2. ASR_API_KEY: required only when ASR_PROVIDER is changed from mock to a real speech provider.
# 3. TTS_API_KEY: required only when TTS_PROVIDER is changed from mock to a real speech provider.
# 4. For iFlytek TTS, set TTS_PROVIDER=xfyun and fill XFYUN_APP_ID/XFYUN_API_KEY/XFYUN_API_SECRET.
# Keep DEMO_MODE=true during rehearsals so the project can fall back to local deterministic answers/audio.
