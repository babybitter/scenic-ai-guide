# 【通用】环境变量示例，复制为 .env 后填入真实值
VITE_VERSION = 3.0.2
VITE_PORT = 3006
VITE_BASE_URL = /
# 权限模式：frontend 前端模式 / backend 后端模式
VITE_ACCESS_MODE = frontend
VITE_WITH_CREDENTIALS = false
VITE_OPEN_ROUTE_INFO = false
VITE_LOCK_ENCRYPT_KEY = please-change-me

# ===== 讯飞交互式虚拟人（数字人）账号凭证 =====
# 在讯飞交互平台申请，浏览器端由 SDK 直接签名使用（构建后内联到前端产物，属客户端可见）。
# avatar_id 与 vcn 由后台数字人配置下发，此处为兜底默认值。
VITE_XF_AVATAR_APPID = your_xfyun_avatar_appid
VITE_XF_AVATAR_APIKEY = your_xfyun_avatar_api_key
VITE_XF_AVATAR_APISECRET = your_xfyun_avatar_api_secret
VITE_XF_AVATAR_SERVERURL = wss://avatar.cn-huadong-1.xf-yun.com/v1/interact
VITE_XF_AVATAR_SCENEID =
VITE_XF_AVATAR_RESKEY =
VITE_XF_AVATAR_ID = cnr5dg8n2000000003
VITE_XF_AVATAR_VCN = x5_lingxiaoyue_flow
